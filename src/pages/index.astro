---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import Stats from '../components/Stats.astro';
import meta from '../../data/meta.json';
import deptList from '../../data/departements-list.json';

const title = "Penurie Carburant France - Station Essence Ouverte | Essence-Disponible.fr";
const description = `Trouvez une station essence ouverte pres de chez vous. ${meta.totalStations} stations suivies, ${meta.totalRupture} en rupture (${meta.tauxRupture}%). Prix gazole, SP95, E10 en temps reel.`;

const topDepts = [...deptList]
  .sort((a, b) => b.stats.tauxRupture - a.stats.tauxRupture)
  .slice(0, 12);

const stationsOuvertes = meta.totalStations - meta.totalRupture;

const faqItems = [
  {
    question: "Ou trouver de l'essence pres de chez moi ?",
    answer: `Utilisez la barre de recherche ci-dessus pour entrer votre code postal ou votre ville. Essence-Disponible.fr affiche les ${meta.totalStations} stations-service de France avec leur disponibilite en temps reel. Actuellement, ${stationsOuvertes} stations sont ouvertes et approvisionnees.`
  },
  {
    question: "Quelles stations sont en rupture de stock ?",
    answer: `En ce moment, ${meta.totalRupture} stations sur ${meta.totalStations} signalent au moins une rupture de carburant, soit un taux de ${meta.tauxRupture}%. Consultez la page de votre departement pour voir le detail par station.`
  },
  {
    question: "Quels sont les prix du carburant aujourd'hui ?",
    answer: `Les prix moyens actuels sont : Gazole ${meta.prixMoyen.gazole?.toFixed(3) || '-'} EUR/L, SP95 ${meta.prixMoyen.sp95?.toFixed(3) || '-'} EUR/L, E10 ${meta.prixMoyen.e10?.toFixed(3) || '-'} EUR/L, SP98 ${meta.prixMoyen.sp98?.toFixed(3) || '-'} EUR/L. Les prix varient selon les departements et les enseignes.`
  },
  {
    question: "Comment signaler une rupture de carburant ?",
    answer: "Sur chaque fiche station, cliquez sur le bouton 'Signaler une rupture' pour informer les autres automobilistes. Les signalements sont verifies et expirent automatiquement apres 2 heures."
  },
  {
    question: "D'ou viennent les donnees affichees ?",
    answer: "Toutes les donnees proviennent de l'API officielle du Ministere de l'Economie (data.economie.gouv.fr), publiees sous Licence Ouverte. Elles sont mises a jour plusieurs fois par jour."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "Essence-Disponible.fr",
      "url": "https://essence-disponible.fr",
      "description": description,
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://essence-disponible.fr/station-essence/{search_term_string}",
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqItems.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    }
  ]
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <!-- Hero -->
  <section class="text-center py-8 md:py-12">
    <h1 class="text-3xl md:text-4xl font-extrabold mb-4 leading-tight">
      Penurie de carburant en France<br />
      <span class="text-[var(--color-primary)]">Trouvez une station ouverte</span>
    </h1>
    <p class="text-[var(--color-text-muted)] mb-6 max-w-2xl mx-auto">
      Consultez les prix, la disponibilite et les ruptures de stock des stations-service pres de chez vous. Donnees officielles mises a jour regulierement.
    </p>
    <SearchBar large />
  </section>

  <!-- Stats -->
  <Stats
    totalStations={meta.totalStations}
    totalRupture={meta.totalRupture}
    tauxRupture={meta.tauxRupture}
    prixMoyen={meta.prixMoyen}
  />

  <!-- Alert Banner -->
  {meta.tauxRupture > 20 && (
    <div class="bg-red-50 border-2 border-red-300 rounded-lg p-4 mb-6 text-center">
      <p class="font-bold text-red-700">
        Alerte penurie : {meta.tauxRupture}% des stations signalent au moins une rupture de stock
      </p>
    </div>
  )}

  <!-- Map Link -->
  <div class="text-center mb-8">
    <a href="/carte/" class="inline-block bg-[var(--color-primary)] text-white px-6 py-3 rounded-lg font-semibold hover:bg-[var(--color-primary-light)] transition shadow">
      Voir la carte des stations
    </a>
  </div>

  <!-- Departments Most Affected -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Departements les plus touches</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
      {topDepts.map(dept => (
        <a href={`/station-essence/${dept.slug}/`}
           class="bg-white rounded-lg shadow p-3 hover:shadow-md transition block">
          <div class="flex items-center justify-between">
            <span class="font-semibold text-sm">{dept.nom} ({dept.code})</span>
            <span class={`text-xs font-bold px-2 py-0.5 rounded-full ${dept.stats.tauxRupture > 50 ? 'bg-red-100 text-red-700' : dept.stats.tauxRupture > 20 ? 'bg-orange-100 text-orange-700' : 'bg-green-100 text-green-700'}`}>
              {dept.stats.tauxRupture}%
            </span>
          </div>
          <div class="text-xs text-[var(--color-text-muted)] mt-1">
            {dept.stats.totalRupture} / {dept.stats.totalStations} en rupture
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- All Departments -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Tous les departements</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-2">
      {deptList.map(dept => (
        <a href={`/station-essence/${dept.slug}/`}
           class="text-sm bg-white rounded px-3 py-2 hover:bg-gray-50 transition text-center shadow-sm">
          <span class="font-medium">{dept.code}</span> - {dept.nom}
        </a>
      ))}
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Questions frequentes sur la penurie de carburant</h2>
    <div class="space-y-3">
      {faqItems.map(faq => (
        <details class="bg-white rounded-lg shadow group">
          <summary class="px-5 py-4 cursor-pointer font-semibold text-sm hover:text-[var(--color-primary)] transition flex items-center justify-between">
            {faq.question}
            <span class="text-[var(--color-text-muted)] group-open:rotate-180 transition-transform" aria-hidden="true">&#9660;</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-[var(--color-text-muted)] leading-relaxed">{faq.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- SEO Content -->
  <section class="bg-white rounded-lg shadow p-6 mb-8">
    <h2 class="text-xl font-bold mb-3">Penurie de carburant en France : situation actuelle</h2>
    <p class="text-sm text-[var(--color-text-muted)] mb-3">
      La penurie de carburant en France touche actuellement <strong>{meta.tauxRupture}% des {meta.totalStations.toLocaleString('fr-FR')} stations-service</strong> du territoire.
      {stationsOuvertes.toLocaleString('fr-FR')} stations restent ouvertes et approvisionnees.
      Le prix moyen du Gazole est de <strong>{meta.prixMoyen.gazole?.toFixed(3) || '-'} EUR/L</strong>,
      le SP95 a <strong>{meta.prixMoyen.sp95?.toFixed(3) || '-'} EUR/L</strong>
      et l'E10 a <strong>{meta.prixMoyen.e10?.toFixed(3) || '-'} EUR/L</strong>.
    </p>
    <p class="text-sm text-[var(--color-text-muted)] mb-3">
      Essence-Disponible.fr vous permet de verifier en temps reel la disponibilite des carburants (Gazole, SP95, E10, SP98, E85, GPLc)
      dans les stations-service pres de chez vous. Entrez votre code postal ou votre ville dans la barre de recherche pour trouver
      les stations ouvertes a proximite, comparer les prix et consulter les horaires d'ouverture.
    </p>
    <p class="text-sm text-[var(--color-text-muted)]">
      Toutes les donnees proviennent de l'API officielle du <a href="https://data.economie.gouv.fr" class="text-[var(--color-primary)] underline" target="_blank" rel="noopener">Ministere de l'Economie</a>,
      publiees sous Licence Ouverte et mises a jour plusieurs fois par jour.
      Vous pouvez egalement <strong>signaler une rupture de stock</strong> pour aider les autres automobilistes.
    </p>
  </section>

  <p class="text-xs text-center text-[var(--color-text-muted)] mb-4">
    Derniere mise a jour : {new Date(meta.lastUpdate).toLocaleString('fr-FR', { dateStyle: 'long', timeStyle: 'short' })}
  </p>
</BaseLayout>
