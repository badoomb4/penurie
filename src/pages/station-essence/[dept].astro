---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Stats from '../../components/Stats.astro';
import StationCard from '../../components/StationCard.astro';
import SearchBar from '../../components/SearchBar.astro';
import deptList from '../../../data/departements-list.json';
import { readFileSync } from 'fs';
import { join } from 'path';

export function getStaticPaths() {
  return deptList.map(dept => ({
    params: { dept: dept.slug },
    props: { deptCode: dept.code, deptNom: dept.nom },
  }));
}

const { dept: deptSlug } = Astro.params;
const { deptCode, deptNom } = Astro.props;

// Load department data
const dataPath = join(process.cwd(), 'data', 'departements', `${deptCode}.json`);
const deptData = JSON.parse(readFileSync(dataPath, 'utf-8'));
const stations = deptData.stations;
const stats = deptData.stats;

const stationsOuvertes = stats.totalStations - stats.totalRupture;
const title = `Station Essence ${deptNom} (${deptCode}) - Prix et Dispo | Essence-Disponible.fr`;
const description = `${stats.totalStations} stations essence dans le ${deptNom} (${deptCode}). ${stats.totalRupture} en rupture, ${stationsOuvertes} ouvertes. Prix moyen gazole ${stats.prixMoyen.gazole?.toFixed(3) || '-'} EUR/L.`;

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: `${deptNom} (${deptCode}) - ${stats.totalStations} stations` },
];

const deptFaq = [
  {
    question: `Combien de stations essence sont ouvertes dans le ${deptNom} ?`,
    answer: `Le departement ${deptNom} (${deptCode}) compte ${stats.totalStations} stations-service. Actuellement, ${stationsOuvertes} stations sont ouvertes et approvisionnees, soit ${100 - stats.tauxRupture}% du total. ${stats.totalRupture} stations signalent au moins une rupture de stock.`
  },
  {
    question: `Quel est le prix du gazole dans le ${deptNom} ?`,
    answer: `Le prix moyen du gazole dans le ${deptNom} est de ${stats.prixMoyen.gazole?.toFixed(3) || '-'} EUR/L. Le SP95 est a ${stats.prixMoyen.sp95?.toFixed(3) || '-'} EUR/L et l'E10 a ${stats.prixMoyen.e10?.toFixed(3) || '-'} EUR/L. Ces prix varient selon les stations et sont mis a jour regulierement.`
  },
  {
    question: `Y a-t-il une penurie de carburant dans le ${deptNom} ?`,
    answer: `Oui, le taux de rupture dans le ${deptNom} est actuellement de ${stats.tauxRupture}%. Consultez la liste des stations ci-dessous pour connaitre l'etat de chaque station en detail.`
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://essence-disponible.fr/" },
        { "@type": "ListItem", "position": 2, "name": `${deptNom} (${deptCode})`, "item": `https://essence-disponible.fr/station-essence/${deptSlug}/` },
      ]
    },
    {
      "@type": "ItemList",
      "name": `Stations essence ${deptNom}`,
      "numberOfItems": stations.length,
      "itemListElement": stations.slice(0, 20).map((s: any, i: number) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "GasStation",
          "name": `Station ${s.adresse}`,
          "address": {
            "@type": "PostalAddress",
            "streetAddress": s.adresse,
            "postalCode": s.cp,
            "addressLocality": s.ville,
            "addressCountry": "FR"
          }
        }
      }))
    },
    {
      "@type": "FAQPage",
      "mainEntity": deptFaq.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
      }))
    }
  ]
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <Breadcrumb items={breadcrumbs} />

  <h1 class="text-2xl md:text-3xl font-extrabold mb-2">
    Stations essence {deptNom} ({deptCode})
  </h1>
  <p class="text-[var(--color-text-muted)] mb-4">
    Prix et disponibilite des carburants dans le departement {deptNom}
  </p>

  <SearchBar />

  <div class="mt-6">
    <Stats
      totalStations={stats.totalStations}
      totalRupture={stats.totalRupture}
      tauxRupture={stats.tauxRupture}
      prixMoyen={stats.prixMoyen}
    />
  </div>

  <!-- Map container -->
  <div id="map" class="h-64 md:h-96 rounded-lg shadow mb-6 bg-gray-100"
       data-stations={JSON.stringify(stations.map((s: any) => ({
         id: s.id, lat: s.lat, lon: s.lon, adresse: s.adresse, ville: s.ville, cp: s.cp,
         rupture: s.ruptures.temporaire.length > 0 || s.ruptures.definitive.length > 0,
         allRupture: s.carburantsDisponibles.length === 0 && (s.ruptures.temporaire.length > 0 || s.ruptures.definitive.length > 0),
         deptSlug: deptSlug,
       })))}>
  </div>

  <!-- Postal Codes -->
  <section class="mb-6">
    <h2 class="text-xl font-bold mb-3">Codes postaux - {deptNom}</h2>
    <div class="flex flex-wrap gap-2">
      {deptData.codesPostaux.map((cp: string) => (
        <a href={`/station-essence/${deptSlug}/${cp}/`}
           class="bg-white border rounded px-3 py-1 text-sm hover:bg-gray-50 transition shadow-sm">
          {cp}
        </a>
      ))}
    </div>
  </section>

  <!-- Stations List -->
  <section>
    <h2 class="text-xl font-bold mb-3">
      {stations.length} stations dans le {deptNom}
    </h2>
    <div class="grid gap-3">
      {stations.map((station: any) => (
        <StationCard station={station} />
      ))}
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="mt-8 mb-6">
    <h2 class="text-xl font-bold mb-3">Questions frequentes - {deptNom}</h2>
    <div class="space-y-3">
      {deptFaq.map(faq => (
        <details class="bg-white rounded-lg shadow group">
          <summary class="px-5 py-4 cursor-pointer font-semibold text-sm hover:text-[var(--color-primary)] transition flex items-center justify-between">
            {faq.question}
            <span class="text-[var(--color-text-muted)] group-open:rotate-180 transition-transform" aria-hidden="true">&#9660;</span>
          </summary>
          <p class="px-5 pb-4 text-sm text-[var(--color-text-muted)] leading-relaxed">{faq.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- SEO Content -->
  <section class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-lg font-bold mb-2">Penurie de carburant dans le {deptNom} ({deptCode})</h2>
    <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
      La penurie de carburant dans le {deptNom} touche actuellement <strong>{stats.tauxRupture}%</strong> des
      {stats.totalStations} stations-service du departement. Sur ces {stats.totalStations} stations,
      <strong>{stationsOuvertes} restent ouvertes</strong> et approvisionnees.
      Le prix moyen du gazole est de <strong>{stats.prixMoyen.gazole?.toFixed(3) || '-'} EUR/L</strong>,
      le SP95 a {stats.prixMoyen.sp95?.toFixed(3) || '-'} EUR/L et l'E10 a {stats.prixMoyen.e10?.toFixed(3) || '-'} EUR/L.
      Consultez la carte ci-dessus et la liste des stations pour trouver du carburant pres de chez vous dans le {deptNom}.
    </p>
  </section>

  <p class="text-xs text-center text-[var(--color-text-muted)] mt-6 mb-4">
    Donnees officielles - Ministere de l'Economie - Mises a jour regulierement
  </p>
</BaseLayout>

<script>
  import '../../scripts/map.js';
</script>
