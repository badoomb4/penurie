---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Stats from '../../components/Stats.astro';
import StationCard from '../../components/StationCard.astro';
import SearchBar from '../../components/SearchBar.astro';
import deptList from '../../../data/departements-list.json';
import { readFileSync } from 'fs';
import { join } from 'path';

export function getStaticPaths() {
  return deptList.map(dept => ({
    params: { dept: dept.slug },
    props: { deptCode: dept.code, deptNom: dept.nom },
  }));
}

const { dept: deptSlug } = Astro.params;
const { deptCode, deptNom } = Astro.props;

// Load department data
const dataPath = join(process.cwd(), 'data', 'departements', `${deptCode}.json`);
const deptData = JSON.parse(readFileSync(dataPath, 'utf-8'));
const stations = deptData.stations;
const stats = deptData.stats;

const title = `Stations essence ${deptNom} (${deptCode}) - Prix et disponibilite`;
const description = `Trouvez les stations essence ouvertes dans le ${deptNom} (${deptCode}). ${stats.totalRupture} stations en rupture sur ${stats.totalStations}. Prix gazole, SP95, E10.`;

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: `${deptNom} (${deptCode})` },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://penurie.fr/" },
        { "@type": "ListItem", "position": 2, "name": `${deptNom} (${deptCode})`, "item": `https://penurie.fr/station-essence/${deptSlug}/` },
      ]
    },
    {
      "@type": "ItemList",
      "name": `Stations essence ${deptNom}`,
      "numberOfItems": stations.length,
      "itemListElement": stations.slice(0, 20).map((s: any, i: number) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "GasStation",
          "name": `Station ${s.adresse}`,
          "address": {
            "@type": "PostalAddress",
            "streetAddress": s.adresse,
            "postalCode": s.cp,
            "addressLocality": s.ville,
            "addressCountry": "FR"
          }
        }
      }))
    }
  ]
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <Breadcrumb items={breadcrumbs} />

  <h1 class="text-2xl md:text-3xl font-extrabold mb-2">
    Stations essence {deptNom} ({deptCode})
  </h1>
  <p class="text-[var(--color-text-muted)] mb-4">
    Prix et disponibilite des carburants dans le departement {deptNom}
  </p>

  <SearchBar />

  <div class="mt-6">
    <Stats
      totalStations={stats.totalStations}
      totalRupture={stats.totalRupture}
      tauxRupture={stats.tauxRupture}
      prixMoyen={stats.prixMoyen}
    />
  </div>

  <!-- Map container -->
  <div id="map" class="h-64 md:h-96 rounded-lg shadow mb-6 bg-gray-100"
       data-stations={JSON.stringify(stations.map((s: any) => ({
         id: s.id, lat: s.lat, lon: s.lon, adresse: s.adresse, ville: s.ville, cp: s.cp,
         rupture: s.ruptures.temporaire.length > 0 || s.ruptures.definitive.length > 0,
         allRupture: s.carburantsDisponibles.length === 0 && (s.ruptures.temporaire.length > 0 || s.ruptures.definitive.length > 0),
         deptSlug: deptSlug,
       })))}>
  </div>

  <!-- Postal Codes -->
  <section class="mb-6">
    <h2 class="text-xl font-bold mb-3">Codes postaux - {deptNom}</h2>
    <div class="flex flex-wrap gap-2">
      {deptData.codesPostaux.map((cp: string) => (
        <a href={`/station-essence/${deptSlug}/${cp}/`}
           class="bg-white border rounded px-3 py-1 text-sm hover:bg-gray-50 transition shadow-sm">
          {cp}
        </a>
      ))}
    </div>
  </section>

  <!-- Stations List -->
  <section>
    <h2 class="text-xl font-bold mb-3">
      {stations.length} stations dans le {deptNom}
    </h2>
    <div class="grid gap-3">
      {stations.map((station: any) => (
        <StationCard station={station} />
      ))}
    </div>
  </section>

  <p class="text-xs text-center text-[var(--color-text-muted)] mt-6 mb-4">
    Derniere mise a jour : {new Date(deptData.stations[0]?.maj?.gazole || Date.now()).toLocaleString('fr-FR', { dateStyle: 'long', timeStyle: 'short' })}
  </p>
</BaseLayout>

<script>
  import '../../scripts/map.js';
</script>
