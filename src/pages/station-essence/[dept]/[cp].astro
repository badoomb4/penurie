---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import Stats from '../../../components/Stats.astro';
import StationCard from '../../../components/StationCard.astro';
import deptList from '../../../../data/departements-list.json';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

export function getStaticPaths() {
  const paths: Array<{ params: { dept: string; cp: string }; props: any }> = [];

  for (const dept of deptList) {
    for (const cp of dept.codesPostaux) {
      paths.push({
        params: { dept: dept.slug, cp },
        props: { deptCode: dept.code, deptNom: dept.nom, deptSlug: dept.slug },
      });
    }
  }

  return paths;
}

const { cp } = Astro.params;
const { deptCode, deptNom, deptSlug } = Astro.props;

// Load postal code data
const cpPath = join(process.cwd(), 'data', 'codes-postaux', `${cp}.json`);
const cpData = existsSync(cpPath) ? JSON.parse(readFileSync(cpPath, 'utf-8')) : { stations: [], stats: { totalStations: 0, totalRupture: 0, tauxRupture: 0, prixMoyen: {} }, ville: '' };
const stations = cpData.stations;
const stats = cpData.stats;
const ville = cpData.ville || cp;

const stationsOuvertes = stats.totalStations - stats.totalRupture;
const title = `Station Essence ${cp} ${ville} - Prix Carburant | Essence-Disponible.fr`;
const description = `${stats.totalStations} stations essence a ${ville} (${cp}). ${stationsOuvertes} ouvertes, ${stats.totalRupture} en rupture. Gazole ${stats.prixMoyen.gazole?.toFixed(3) || '-'} EUR/L. Horaires et services.`;

// Find sibling postal codes — show up to 20 for better internal linking
const deptInfo = deptList.find((d: any) => d.code === deptCode);
const siblingCPs = deptInfo?.codesPostaux.filter((c: string) => c !== cp).slice(0, 20) || [];

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: `${deptNom} (${deptCode})`, href: `/station-essence/${deptSlug}/` },
  { label: `${cp} ${ville}` },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://essence-disponible.fr/" },
        { "@type": "ListItem", "position": 2, "name": `${deptNom} (${deptCode})`, "item": `https://essence-disponible.fr/station-essence/${deptSlug}/` },
        { "@type": "ListItem", "position": 3, "name": `${cp} ${ville}`, "item": `https://essence-disponible.fr/station-essence/${deptSlug}/${cp}/` },
      ]
    },
    ...stations.map((s: any) => ({
      "@type": "GasStation",
      "name": `Station ${s.adresse}`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": s.adresse,
        "postalCode": s.cp,
        "addressLocality": s.ville,
        "addressCountry": "FR"
      },
      ...(s.lat && s.lon ? {
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": s.lat,
          "longitude": s.lon,
        }
      } : {}),
      "openingHours": s.automate24h ? "Mo-Su 00:00-23:59" : undefined,
      "amenityFeature": s.services?.map((svc: string) => ({
        "@type": "LocationFeatureSpecification",
        "name": svc,
        "value": true
      })),
      "offers": Object.entries(s.prix)
        .filter(([, price]: [string, any]) => price && price > 0)
        .map(([fuel, price]: [string, any]) => {
          const ruptureList = [...(s.ruptures?.temporaire || []), ...(s.ruptures?.definitive || [])].map((r: string) => r.toLowerCase());
          const isRupture = ruptureList.includes(fuel.toLowerCase());
          return {
            "@type": "Offer",
            "name": fuel.toUpperCase(),
            "price": price,
            "priceCurrency": "EUR",
            "availability": isRupture ? "https://schema.org/OutOfStock" : "https://schema.org/InStock",
          };
        }),
    })),
  ]
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <Breadcrumb items={breadcrumbs} />

  <h1 class="text-2xl md:text-3xl font-extrabold mb-2">
    Stations essence {cp} {ville}
  </h1>
  <p class="text-[var(--color-text-muted)] mb-4">
    Disponibilite et prix des carburants a {ville} ({deptNom})
  </p>

  {stats.totalStations > 0 && (
    <Stats
      totalStations={stats.totalStations}
      totalRupture={stats.totalRupture}
      tauxRupture={stats.tauxRupture}
      prixMoyen={stats.prixMoyen}
    />
  )}

  <!-- Map -->
  <div id="map" class="h-64 md:h-80 rounded-lg shadow mb-6 bg-gray-100"
       data-stations={JSON.stringify(stations.map((s: any) => ({
         id: s.id, lat: s.lat, lon: s.lon, adresse: s.adresse, ville: s.ville, cp: s.cp,
         rupture: s.ruptures.temporaire.length > 0 || s.ruptures.definitive.length > 0,
         allRupture: s.carburantsDisponibles.length === 0 && (s.ruptures.temporaire.length > 0 || s.ruptures.definitive.length > 0),
         deptSlug,
       })))}>
  </div>

  <!-- Stations -->
  <section class="mb-6">
    <h2 class="text-xl font-bold mb-3">
      {stations.length} station{stations.length > 1 ? 's' : ''} a {ville} ({cp})
    </h2>
    <div class="grid gap-4">
      {stations.map((station: any) => (
        <StationCard station={station} detailed />
      ))}
    </div>
  </section>

  <!-- Sibling Postal Codes -->
  {siblingCPs.length > 0 && (
    <section class="mb-6">
      <h2 class="text-lg font-bold mb-2">Codes postaux voisins - {deptNom}</h2>
      <div class="flex flex-wrap gap-2">
        {siblingCPs.map((sibCp: string) => (
          <a href={`/station-essence/${deptSlug}/${sibCp}/`}
             class="bg-white border rounded px-3 py-1 text-sm hover:bg-gray-50 transition shadow-sm">
            {sibCp}
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- SEO Content -->
  <section class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-lg font-bold mb-2">Stations-service a {ville} ({cp})</h2>
    <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
      A {ville} ({cp}, {deptNom}), <strong>{stats.totalStations} station{stats.totalStations > 1 ? 's' : ''}-service</strong> sont
      recensees. Actuellement, <strong>{stationsOuvertes} station{stationsOuvertes > 1 ? 's sont ouvertes' : ' est ouverte'}</strong>
      {stats.totalRupture > 0 ? ` et ${stats.totalRupture} signale${stats.totalRupture > 1 ? 'nt' : ''} une rupture de stock` : ''}.
      {stats.prixMoyen.gazole ? ` Le gazole est en moyenne a ${stats.prixMoyen.gazole.toFixed(3)} EUR/L` : ''}
      {stats.prixMoyen.sp95 ? `, le SP95 a ${stats.prixMoyen.sp95.toFixed(3)} EUR/L` : ''}
      {stats.prixMoyen.e10 ? ` et l'E10 a ${stats.prixMoyen.e10.toFixed(3)} EUR/L` : ''}.
      Consultez les horaires, services et disponibilite detaillee de chaque station ci-dessus.
    </p>
  </section>

  <p class="text-xs text-center text-[var(--color-text-muted)] mt-6 mb-4">
    Donnees officielles - Ministere de l'Economie - Mises a jour regulierement
  </p>
</BaseLayout>

<script>
  import '../../../scripts/map.js';
</script>
