---
interface Props {
  slot: 'header' | 'mid-content' | 'footer' | 'sidebar';
  format?: 'horizontal' | 'rectangle' | 'responsive';
}

const { slot, format = 'responsive' } = Astro.props;

// Ad slot IDs — replace with your real AdSense ad unit IDs
const slotConfig: Record<string, { style: string; adSlot: string }> = {
  'header': {
    style: 'display:block',
    adSlot: 'XXXXXXXXXX', // Replace with your ad unit ID
  },
  'mid-content': {
    style: 'display:block',
    adSlot: 'XXXXXXXXXX',
  },
  'footer': {
    style: 'display:block',
    adSlot: 'XXXXXXXXXX',
  },
  'sidebar': {
    style: 'display:block',
    adSlot: 'XXXXXXXXXX',
  },
};

const config = slotConfig[slot];
---

<div class={`ad-container my-4 text-center ${slot === 'header' ? 'mb-2' : ''}`} data-ad-slot={slot}>
  <!-- Google AdSense -->
  <!--
    To activate:
    1. Replace ca-pub-XXXXXXX with your AdSense publisher ID in BaseLayout.astro
    2. Replace XXXXXXXXXX with your ad unit IDs above
    3. Uncomment the ins tag below
  -->
  <!--
  <ins class="adsbygoogle"
    style={config.style}
    data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
    data-ad-slot={config.adSlot}
    data-ad-format={format === 'rectangle' ? 'rectangle' : 'auto'}
    data-full-width-responsive="true">
  </ins>
  <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  -->

  <!-- Placeholder visible en dev -->
  <div class="bg-gray-100 border-2 border-dashed border-gray-300 rounded-lg p-3 text-xs text-gray-400 hidden" id={`ad-placeholder-${slot}`}>
    Espace publicitaire — {slot}
  </div>
</div>
