---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object;
}

const { title, description, canonical, ogImage = '/og-image.png', schema } = Astro.props;
const currentUrl = canonical || Astro.url.href;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={currentUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={currentUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="fr_FR" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Leaflet CSS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin="" />

  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
</head>
<body class="bg-[var(--color-bg)] text-[var(--color-text)] min-h-screen flex flex-col">
  <!-- Navigation -->
  <nav class="bg-[var(--color-primary)] text-white shadow-lg sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="text-xl font-bold tracking-tight hover:opacity-90">
        <span class="text-yellow-300">&#9981;</span> Penurie.fr
      </a>
      <div class="hidden md:flex gap-6 text-sm font-medium">
        <a href="/" class="hover:text-yellow-200 transition">Accueil</a>
        <a href="/carte/" class="hover:text-yellow-200 transition">Carte</a>
        <a href="/penurie-carburant/" class="hover:text-yellow-200 transition">Ruptures</a>
        <a href="/prix-carburants/" class="hover:text-yellow-200 transition">Prix</a>
      </div>
      <button id="mobile-menu-btn" class="md:hidden p-2" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden px-4 pb-3 space-y-2 text-sm">
      <a href="/" class="block py-1 hover:text-yellow-200">Accueil</a>
      <a href="/carte/" class="block py-1 hover:text-yellow-200">Carte</a>
      <a href="/penurie-carburant/" class="block py-1 hover:text-yellow-200">Ruptures</a>
      <a href="/prix-carburants/" class="block py-1 hover:text-yellow-200">Prix</a>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="flex-1 max-w-7xl mx-auto px-4 py-6 w-full">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-gray-800 text-gray-300 mt-auto">
    <div class="max-w-7xl mx-auto px-4 py-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-sm">
        <div>
          <h3 class="font-bold text-white mb-2">Penurie.fr</h3>
          <p>Trouvez les stations essence ouvertes pres de chez vous. Donnees officielles mises a jour regulierement.</p>
        </div>
        <div>
          <h3 class="font-bold text-white mb-2">Navigation</h3>
          <ul class="space-y-1">
            <li><a href="/" class="hover:text-white transition">Accueil</a></li>
            <li><a href="/carte/" class="hover:text-white transition">Carte des stations</a></li>
            <li><a href="/penurie-carburant/" class="hover:text-white transition">Etat des ruptures</a></li>
            <li><a href="/prix-carburants/" class="hover:text-white transition">Prix des carburants</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-white mb-2">Informations</h3>
          <ul class="space-y-1">
            <li><a href="/a-propos/" class="hover:text-white transition">A propos / Mentions legales</a></li>
          </ul>
          <p class="mt-3 text-xs text-gray-400">
            Donnees : <a href="https://data.economie.gouv.fr" class="underline hover:text-white" target="_blank" rel="noopener">data.economie.gouv.fr</a> — Licence ouverte
          </p>
        </div>
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  </script>
</body>
</html>
